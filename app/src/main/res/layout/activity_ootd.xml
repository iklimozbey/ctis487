<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header badge -->
            <TextView
                android:id="@+id/tvOotdBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stylists_pick"
                android:textColor="@color/black"
                android:background="@color/accent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:letterSpacing="0.1" />

            <!-- Outfit name -->
            <TextView
                android:id="@+id/tvOotdTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/weekend_minimalist"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="-4dp"
                android:letterSpacing="0.02" />

            <!-- Weather + event info row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvWeather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/weather"
                    android:textColor="@color/white"
                    android:background="@drawable/ctx_pill_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textSize="12sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvEvents"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/events"
                    android:textColor="@color/white"
                    android:background="@drawable/ctx_pill_bg"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Loading state -->
            <LinearLayout
                android:id="@+id/layoutLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="40dp"
                android:visibility="visible">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottieOotd"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:lottie_rawRes="@raw/loading_animation"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true" />

                <TextView
                    android:id="@+id/tvLoadingMsg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Curating your look..."
                    android:textColor="@color/warm_gray"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:textStyle="italic" />
            </LinearLayout>

            <!-- Content (hidden while loading) -->
            <LinearLayout
                android:id="@+id/layoutContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Item thumbnails -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/outfit_pieces"
                        android:textColor="@color/accent"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVisualize"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/visualize"
                        android:textColor="@color/accent"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:icon="@drawable/ic_ootd"
                        app:iconSize="14dp"
                        app:iconTint="@color/accent"
                        android:padding="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:visibility="gone" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutItems"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />
                </HorizontalScrollView>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/border_color"
                    android:layout_marginVertical="24dp" />

                <!-- Expert Reasoning -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EXPERT REASONING"
                    android:textColor="@color/accent"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvReasoning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/analyzing_dna"
                    android:textColor="@color/warm_gray"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="serif"
                    android:textStyle="italic" />

            </LinearLayout>

            <!-- Error state -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FF6B6B"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="24dp"
                android:visibility="gone" />

            <!-- Regenerate button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGenerateOotd"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/regenerate_look"
                android:layout_marginTop="32dp"
                android:backgroundTint="@color/accent"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="32dp" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:backgroundTint="@color/black"
        app:itemIconTint="@color/warm_gray"
        app:itemTextColor="@color/warm_gray"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>