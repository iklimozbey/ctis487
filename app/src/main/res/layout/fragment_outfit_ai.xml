<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvAiTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/outfit_ai"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayoutSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:boxBackgroundColor="@color/card_bg"
        app:boxStrokeColor="@color/border_color"
        app:hintTextColor="@color/text_muted"
        android:textColorHint="@color/text_muted"
        app:layout_constraintTop_toBottomOf="@id/tvAiTitle">

        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:hint="@string/search_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGenerate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="@string/generate_output"
        android:textColor="@color/black"
        app:backgroundTint="@color/accent"
        app:layout_constraintTop_toBottomOf="@id/inputLayoutSearch"/>

</androidx.constraintlayout.widget.ConstraintLayout>