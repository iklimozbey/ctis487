<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme strictly mimicking the web dark theme -->
    <style name="Base.Theme.SmartWardrobe" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/card_bg</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/black</item>
        
        <item name="android:windowBackground">@color/black</item>
        <item name="android:textColor">@color/white</item>
        <item name="colorSurface">@color/card_bg</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:navigationBarColor">@color/black</item>
        <!-- Modern sleek typography -->
        <item name="android:fontFamily">sans-serif-light</item>
    </style>
    
    <style name="Theme.SmartWardrobe" parent="Base.Theme.SmartWardrobe" />
</resources>